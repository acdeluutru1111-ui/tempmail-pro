# Telegram Bot (REQUIRED)
BOT_TOKEN=your_bot_token_from_botfather

# Bot Username (for referral links)
BOT_USERNAME=YourBotUsername

# Cloudflare Worker URL (sau khi deploy worker)
CLOUDFLARE_WORKER_URL=https://tempmail-worker.vieclamhanam1234.workers.dev

# API Key để bảo vệ Worker (phải giống với secret đã set trong Worker)
WORKER_API_KEY=tempmail-pro-secret-2026

# SmailPro Cookies (optional - fallback if no worker)
XSRF_TOKEN=your_xsrf_token
SONJJ_SESSION=your_session_token

# Internal security
INTERNAL_KEY=random_secret_key_change_this

# CPA Networks (optional)
CPAGRIP_USER_ID=your_user_id

# Payments (optional - for premium subscriptions)
PAYMENT_PROVIDER_TOKEN=your_stripe_test_token

# Server
PORT=7860
